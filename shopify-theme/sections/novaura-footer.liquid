{% comment %}
  NovAura Footer - Multi-column with gradient accents
{% endcomment %}

<footer class="novaura-footer">
  <div class="container">
    <div class="novaura-footer__grid">
      <div class="novaura-footer__brand">
        <div class="novaura-footer__logo">{{ section.settings.logo_text }}</div>
        <p class="novaura-footer__tagline">{{ section.settings.tagline }}</p>
      </div>
      
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'link_list' %}
            <div class="novaura-footer__column" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="novaura-footer__heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.menu != blank %}
                <ul class="novaura-footer__links">
                  {% for link in block.settings.menu.links %}
                    <li>
                      <a href="{{ link.url }}">{{ link.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>
          {% when 'text' %}
            <div class="novaura-footer__column" {{ block.shopify_attributes }}>
              {% if block.settings.heading != blank %}
                <h3 class="novaura-footer__heading">{{ block.settings.heading }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <div style="color: var(--color-text-secondary); font-size: 1.5rem; line-height: 1.6;">
                  {{ block.settings.text }}
                </div>
              {% endif %}
            </div>
        {% endcase %}
      {% endfor %}
    </div>
    
    <div class="novaura-footer__bottom">
      <p class="novaura-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      
      {% if section.settings.show_social %}
        <div class="novaura-footer__socials">
          {% if section.settings.social_facebook != blank %}
            <a href="{{ section.settings.social_facebook }}" class="novaura-footer__social" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" class="novaura-footer__social" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_twitter != blank %}
            <a href="{{ section.settings.social_twitter }}" class="novaura-footer__social" target="_blank" rel="noopener" aria-label="Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_youtube != blank %}
            <a href="{{ section.settings.social_youtube }}" class="novaura-footer__social" target="_blank" rel="noopener" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
              </svg>
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "NovAura Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo Text",
      "default": "Catalyst's Corner"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Home wares & tech items galore. Curated essentials for the modern lifestyle."
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Have questions? We're here to help.</p>"
        }
      ]
    }
  ],
  "max_blocks": 4
}
{% endschema %}
