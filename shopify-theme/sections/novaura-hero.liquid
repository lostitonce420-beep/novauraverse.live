{% comment %}
  NovAura Hero Section - Catalyst's Corner
  Features: Animated gradient background, RGB text effects, CTA buttons
{% endcomment %}

<div class="novaura-hero">
  <div class="novaura-hero__grid"></div>
  
  <div class="novaura-hero__content">
    {% if section.settings.eyebrow != blank %}
      <div class="novaura-hero__badge">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 3h18v18H3zM9 3v18M15 3v18M3 9h18M3 15h18"/>
        </svg>
        {{ section.settings.eyebrow }}
      </div>
    {% endif %}
    
    <h1 class="novaura-hero__title">
      {{ section.settings.heading | replace: '<span>', '<span class="text-gradient-rgb">' }}
    </h1>
    
    {% if section.settings.subheading != blank %}
      <p class="novaura-hero__subtitle">{{ section.settings.subheading }}</p>
    {% endif %}
    
    <div class="novaura-hero__buttons">
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link }}" class="novaura-hero__cta">
          {{ section.settings.button_label }}
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {% endif %}
      
      {% if section.settings.secondary_button_label != blank %}
        <a href="{{ section.settings.secondary_button_link }}" class="novaura-button novaura-button--secondary">
          {{ section.settings.secondary_button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .novaura-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 3rem;
  }
</style>

{% schema %}
{
  "name": "NovAura Hero",
  "tag": "section",
  "class": "section-novaura-hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Catalyst's Corner"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Home Wares & Tech <span>Galore</span>"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover curated home essentials, cutting-edge tech gadgets, and lifestyle products that elevate your everyday experience."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary Button Label",
      "default": "View Catalog"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "NovAura Hero"
    }
  ]
}
{% endschema %}
