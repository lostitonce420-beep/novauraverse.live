{% comment %}
  NovAura Announcement Bar
{% endcomment %}

{% if section.settings.show_announcement %}
  <div class="novaura-announcement">
    <div class="container">
      {% if section.settings.link != blank %}
        <a href="{{ section.settings.link }}" style="color: inherit;">
          {{ section.settings.text }}
        </a>
      {% else %}
        {{ section.settings.text }}
      {% endif %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on orders over $50! 🚀"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
